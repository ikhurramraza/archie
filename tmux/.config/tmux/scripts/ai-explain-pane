#!/usr/bin/env bash

set -euo pipefail

# Capture the recent scrollback of a pane and ask Claude to explain it — handy
# for "why did this fail?" without leaving tmux or copy-pasting. The answer is
# shown in a pager so the popup stays open and scrollable until you quit (q).
#
# Tunables (env): AI_EXPLAIN_LINES (scrollback depth), AI_EXPLAIN_MODEL.

main() {
  # tmux does not expand formats in a display-popup command argument, so resolve
  # the active (underlying) pane here rather than relying on a passed-in id.
  local pane="${1:-$(tmux display-message -p '#{pane_id}')}"
  local lines="${AI_EXPLAIN_LINES:-200}"
  local model="${AI_EXPLAIN_MODEL:-sonnet}"

  local context
  context="$(tmux capture-pane -p -t "$pane" -S "-${lines}")"

  local prompt
  prompt="The text below is the recent output of my terminal. Briefly explain what is \
happening. If there is an error or failure, identify the most likely cause and how to \
fix it. Be concise and use short sections.

--- TERMINAL ---
${context}"

  printf '🤖 Asking Claude…\n'

  local answer
  answer="$(claude -p "$prompt" --model "$model" 2>&1)" || true

  printf '%s\n' "$answer" | less -R
}

main "$@"
