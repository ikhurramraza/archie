#!/usr/bin/zsh

# Configure Pipenv
export PIPENV_VENV_IN_PROJECT=enabled
export PIPENV_VERBOSITY=-1

# Configure IRB
export IRBRC="$XDG_CONFIG_HOME/irb/irbrc"

# Configure gemrc
export GEMRC="$XDG_CONFIG_HOME/gems/gemrc"

# Configure SQLite
export SQLITE_HISTORY="$XDG_DATA_HOME/sqlite/history"

# Configure pass
export PASSWORD_STORE_DIR="$XDG_DATA_HOME/pass"

# Configure notie
export NOTIE_DIRECTORY="/mnt/Notes"

# Init OMZ
zstyle ':omz:*' aliases no
zstyle ':omz:plugins:bundler' aliases yes
zstyle ':omz:plugins:z' aliases yes
zstyle ':omz:update' mode disabled
export BUNDLED_COMMANDS=(good_job rails stree)
export CASE_SENSITIVE=true
export DISABLE_UPDATE_PROMPT=true
export DISABLE_MAGIC_FUNCTIONS=true
mkdir -p "$XDG_CACHE_HOME/zsh"
export ZSH_COMPDUMP="$XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION"
source "$ZSH/oh-my-zsh.sh"

# Init starship
export STARSHIP_LOG="error" # Disable command timeout errors
which starship &>/dev/null && eval "$(starship init zsh)"

# Enable option stacking auto completion for docker
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/zcompcache"

# Configure MISE
if which mise &>/dev/null; then
  eval "$(mise activate zsh)"
  eval "$(mise complete --shell zsh)"

  export MISE_RUBY_DEFAULT_PACKAGES_FILE="$XDG_CONFIG_HOME/mise/ruby/default_gems"
  export MISE_NODE_DEFAULT_PACKAGES_FILE="$XDG_CONFIG_HOME/mise/nodejs/default_npm_packages"
  export MISE_PYTHON_DEFAULT_PACKAGES_FILE="$XDG_CONFIG_HOME/mise/python/default_python_packages"
fi

# Add GPG key
export GPG_TTY=$(tty)

# Setup atuin
which atuin &>/dev/null && eval "$(atuin init zsh --disable-up-arrow)"

# Setup carapace
which carapace &>/dev/null && source <(carapace _carapace)

# Ctrl+x Ctrl+e to edit current command in $EDITOR
autoload -U edit-command-line
zle -N edit-command-line
bindkey "^X^E" edit-command-line

# Ctrl+x Ctrl+a to turn a plain-English request on the prompt into a shell
# command via Claude. Type what you want, hit the chord, then edit and run.
_claude_command_line() {
  emulate -L zsh

  local request="$BUFFER"
  [[ -z "$request" ]] && return

  zle -R "🤖 Asking Claude…"

  # NB: do not name this `prompt` — in zsh that is a synonym for PS1, so a local
  # `prompt` gets painted as the shell prompt by `reset-prompt` below.
  local query="Translate the request below into a single shell command for zsh on Linux. \
Output only the command: no explanation, no prose, no markdown, no code fences. \
Request: $request"

  local answer
  answer="$(claude -p "$query" --model "${CLAUDE_CLI_MODEL:-haiku}" </dev/null 2>/dev/null)"

  # Defensively strip stray code fences and flatten to a single line.
  answer="${answer//\`\`\`/}"
  answer="${answer//$'\n'/ }"
  answer="${answer## }"
  answer="${answer%% }"

  if [[ -n "$answer" ]]; then
    BUFFER="$answer"
    CURSOR=${#BUFFER}
  fi

  zle reset-prompt
}
zle -N _claude_command_line
bindkey "^X^A" _claude_command_line

# Set catppuccin theme for fzf
export FZF_DEFAULT_OPTS=" \
--color=bg+:#000000,bg:#000000,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

# Configure difftastic
export DFT_DISPLAY=side-by-side
export DFT_BACKGROUND=dark
export DFT_SYNTAX_HIGHLIGHT=on
export DFT_TAB_WIDTH=2
export DFT_CONTEXT=3
export DFT_PARSE_ERROR_LIMIT=5
export DFT_GRAPH_LIMIT=1000000
