[advice]
  statusHints = false

[blame]
  markIgnoredLines = true

[branch]
  sort = -committerdate

[commit]
  gpgsign = true
  verbose = true

[core]
  excludesfile   = ~/.config/git/global_gitignore
  attributesfile = ~/.config/git/gitattributes

[diff]
  algorithm = histogram
  colorMoved = default
  mnemonicprefix = true
  renames = copies

[fetch]
  prune = true

[filter "lfs"]
  clean    = git-lfs clean -- %f
  process  = git-lfs filter-process
  required = true
  smudge   = git-lfs smudge -- %f

[gui]
  skipDiscardChangeWarning = true

[init]
  defaultBranch = main

[merge]
  conflictStyle = zdiff3

[pull]
  twohead = ort

[push]
  autoSetupRemote = true
  default = simple

[rebase]
  abbreviateCommands = true
  autosquash = true
  updateRefs = true

[rerere]
  enabled = true

